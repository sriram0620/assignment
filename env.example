# ═══════════════════════════════════════════════════════════════════════════════
#  AI-HRMS — Environment Variables
#  Copy this file to .env.local and fill in every value marked ✅ Required.
#  Restart the dev server after any change.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Authentication (JWT signing) ─────────────────────────────────────────────
# ✅ Required. Must be at least 32 random characters.
# Generate: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# ─── Supabase ─────────────────────────────────────────────────────────────────
# ✅ Required.
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
# Optional — graceful fallback to base scoring if missing.
# Get from: https://aistudio.google.com/app/apikey → Create API key (free tier)
# Powers: Productivity scoring, skill gap detection, smart task assignment
GEMINI_API_KEY=your-gemini-api-key

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Optional — employee welcome emails. Free tier: 3,000 emails/month.
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_TEST_TO=your-resend-account-email@example.com


